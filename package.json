    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "expo-mcp": "~0.2.1",
    "jest": "^30.3.0",
