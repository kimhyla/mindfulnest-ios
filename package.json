{
  "name": "mindfulnest",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "engines": {
    "node": ">=22.11.0 <23",
    "npm": ">=10.9.0"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
