{
  "$comment": "MindfulNest Firestore schema lockfile \u2014 authoritative type source for both Lovable dashboard repos per LD-185. Covers 12 collections per LD-188.",
  "_meta": {
    "schema_version": 1,
    "locked": "2026-04-18",
    "locked_by": "Wave B2 WB-C8-json",
    "ld_refs": [
      "LD-185 DASHBOARD_ARCH_TWO_REPOS_SHARED_SCHEMA",
      "LD-188 FIRESTORE_SCHEMA_LOCKFILE_COVERS_12_COLLECTIONS",
      "LD-225 COPPA_DATA_MINIMIZATION",
      "LD-226 COPPA_PARENT_CHILD_NESTING_REQUIRED",
      "LD-216 COPPA_VPC_VIA_KWS_ONLY"
    ],
    "notes": "Field allowlists align with firestore.rules v5 COPPA hardening. Dashboard repos regenerate TypeScript types from this file at build time via scripts/generate-types.ts. CI rejects drift. 2026-04-18: added therapist_summaries for S3-CF-therapist-summary (preflight 69)."
  },
  "collections": {
    "children": {
      "description": "COPPA-regulated child records. Parent-scoped. Accessed via parent auth only.",
      "parent_collection": "parents",
      "parent_fk": "linkedParent",
      "required_fields": [
        "linkedParent",
        "linkedTherapist",
        "displayName",
        "parental_consent_verified",
        "parental_consent_source",
        "kws_parent_id"
      ],
      "allowlist_fields": [
        "linkedParent",
        "linkedTherapist",
        "displayName",
        "date_of_birth",
        "gender",
        "current_module_id",
        "current_phase",
        "current_checkpoint_id",
        "parental_consent_verified",
        "parental_consent_source",
        "kws_parent_id",
        "consent_status",
        "consent_scope",
        "last_session_timestamp",
        "retention_clock_started_at",
        "created_at",
        "updated_at",
        "preferredTechniques",
        "chatEnabled",
        "parentNotifiedSkills",
        "therapistFirstCompletionNotified",
        "inactivityNotifiedAt",
        "totalSessions",
        "sessionsThisWeek",
        "domainSessionCounts",
        "completions",
        "lastActivityAt",
        "engagementStatus",
        "weekStartDate"
      ],
      "forbidden_fields": [
        "last_name",
        "school",
        "address",
        "phone",
        "childEmail",
        "child_email",
        "email",
        "ip_address",
        "ip_logs",
        "device_id",
        "device_fingerprint",
        "photo_url",
        "avatar_image",
        "chosen_guide_name",
        "clinical_notes",
        "diagnosis",
        "clq_score",
        "gpr_score"
      ],
      "field_types": {
        "linkedParent": "string (FK \u2192 parents.id)",
        "linkedTherapist": "string (FK \u2192 therapists.id) | nullable",
        "displayName": "string (first name only)",
        "date_of_birth": "ISO date string (derive age at read)",
        "gender": "'boy' | 'girl' (per LD CONTENT_BINARY_GENDER_ONLY)",
        "current_module_id": "string (e.g., 'M1')",
        "current_phase": "'intro' | 'phase_a' | 'phase_b' | 'resolution' | 'win' | 'decoration'",
        "current_checkpoint_id": "string | null",
        "parental_consent_verified": "boolean (must be true)",
        "parental_consent_source": "'kws' (LD-216 only valid value)",
        "kws_parent_id": "string (non-empty)",
        "consent_status": "'pending' | 'verified' | 'revoked'",
        "consent_scope": "string[] (e.g., ['therapist_progress_view']) \u2014 'elevenlabs_tts' REMOVED 2026-04-18 per LD-281 NO_RUNTIME_TTS_PERSONALIZATION_V1 (app has no runtime ElevenLabs integration)",
        "last_session_timestamp": "timestamp",
        "retention_clock_started_at": "timestamp | null (Cloud Function writes only)",
        "created_at": "timestamp",
        "updated_at": "timestamp"
      }
    },
    "parents": {
      "description": "COPPA-verified parent accounts. Firebase Auth UID = parent doc ID.",
      "required_fields": [
        "displayName",
        "email",
        "kws_parent_id"
      ],
      "field_types": {
        "displayName": "string",
        "email": "string",
        "linkedTherapist": "string | null (FK \u2192 therapists.id, primary therapist)",
        "coppaChatConsent": "boolean",
        "kws_parent_id": "string (non-empty; links to KWS portal)",
        "stripe_customer_id": "string | null",
        "created_at": "timestamp"
      }
    },
    "therapists": {
      "description": "Therapist (distributor) accounts. Firebase Auth UID = therapist doc ID.",
      "required_fields": [
        "displayName",
        "email"
      ],
      "field_types": {
        "displayName": "string",
        "email": "string",
        "status": "'active' | 'deactivated' | 'suspended'",
        "deactivatedAt": "timestamp | null",
        "deactivationReason": "string | null",
        "rewardful_affiliate_id": "string | null (LD-206)",
        "created_at": "timestamp"
      }
    },
    "sessions": {
      "description": "Child session records. Parent/therapist-scoped read per linkedParent/linkedTherapist.",
      "parent_collection": "children",
      "required_fields": [
        "childId",
        "startedAt",
        "endedAt"
      ],
      "field_types": {
        "childId": "string (FK \u2192 children.id)",
        "moduleId": "string",
        "phase": "string",
        "startedAt": "timestamp",
        "endedAt": "timestamp",
        "completionStatus": "'in_progress' | 'completed' | 'abandoned'"
      }
    },
    "clq_responses": {
      "description": "CRI CLQ questionnaire responses. Child-scoped subcollection.",
      "parent_collection": "children",
      "required_fields": [
        "childId",
        "administered_at",
        "administered_by"
      ],
      "field_types": {
        "childId": "string (FK \u2192 children.id)",
        "administered_at": "timestamp",
        "administered_by": "'therapist' | 'parent' | 'child'",
        "responses": "map<item_id, response>",
        "is_baseline": "boolean"
      }
    },
    "gpr_entries": {
      "description": "CRI GPR goal progress records. Child-scoped subcollection.",
      "parent_collection": "children",
      "required_fields": [
        "childId",
        "recorded_at"
      ],
      "field_types": {
        "childId": "string",
        "recorded_at": "timestamp",
        "goal_id": "string",
        "progress_delta": "number",
        "notes": "string"
      }
    },
    "zaps": {
      "description": "Child-authored messages to creatures. Sanitization-required (LD-171).",
      "parent_collection": "children",
      "required_fields": [
        "childId",
        "creatureId",
        "content",
        "sent_at"
      ],
      "field_types": {
        "childId": "string",
        "creatureId": "'M1' | 'M2' | 'M3' | 'M4' | 'M5' | 'M6'",
        "content": "string (sanitized via Cloud Function per LD-171)",
        "sent_at": "timestamp"
      }
    },
    "wishing_garden_entries": {
      "description": "Child-authored Wishing Garden contributions. Sanitization-required.",
      "parent_collection": "children",
      "required_fields": [
        "childId",
        "created_at"
      ],
      "field_types": {
        "childId": "string",
        "prompt": "string",
        "response": "string (sanitized)",
        "created_at": "timestamp"
      }
    },
    "coach_conversations": {
      "description": "AI Parent Coach chat threads. Parent-scoped. Claude API backend per LD-87.",
      "parent_collection": "parents",
      "required_fields": [
        "parentId",
        "created_at"
      ],
      "field_types": {
        "parentId": "string (FK \u2192 parents.id)",
        "created_at": "timestamp",
        "messages": "array<{role, content, timestamp, model_used}>",
        "monthly_message_count": "number (soft-cap per Kim)"
      }
    },
    "stripe_customers": {
      "description": "Stripe customer mirror (from firestore-stripe-payments Firebase extension per LD-207).",
      "managed_by_extension": "invertase/firestore-stripe-payments",
      "field_types": {
        "stripeId": "string",
        "stripeLink": "string",
        "email": "string"
      }
    },
    "commission_events": {
      "description": "Therapist commission events (from Rewardful webhook per LD-206).",
      "required_fields": [
        "therapistId",
        "parentId",
        "amount_cents",
        "event_at"
      ],
      "field_types": {
        "therapistId": "string",
        "parentId": "string (triggering purchase)",
        "amount_cents": "integer (tier: 20000, 22500, 25000, 27500)",
        "event_at": "timestamp",
        "status": "'pending' | 'paid' | 'reversed'"
      }
    },
    "modules": {
      "description": "Content catalog \u2014 arcs \u00d7 creatures \u00d7 techniques. Published-only read for authenticated users.",
      "required_fields": [
        "id",
        "status"
      ],
      "field_types": {
        "id": "string (e.g., 'A1M1')",
        "arc": "number",
        "creature_m_number": "'M1' | 'M2' | 'M3' | 'M4' | 'M5' | 'M6'",
        "technique_name": "string",
        "status": "'draft' | 'published' | 'retired'"
      }
    },
    "therapist_summaries": {
      "description": "Pre-computed therapist dashboard summary per child (LD-165). CF-only writes via admin SDK; therapist read via isChildsTherapist. Document ID = childId. Shape is LD-225-compliant: bucketed counts + activity enum only, NO raw event timestamps (pattern-reveal defense per S3-CF-therapist-summary Phase 0 synthesis).",
      "required_fields": [
        "childId",
        "updated_at",
        "activity_bucket"
      ],
      "allowlist_fields": [
        "childId",
        "updated_at",
        "zaps_7d",
        "zaps_30d",
        "garden_30d",
        "sessions_30d",
        "clq_latest_score",
        "clq_latest_at_bucket",
        "gpr_active_goal_count",
        "gpr_avg_7d",
        "active_this_week",
        "activity_bucket",
        "_last_source"
      ],
      "forbidden_fields": [
        "last_zap_at",
        "last_entry_at",
        "last_session_at",
        "content_preview",
        "message_preview",
        "clq_responses_inline",
        "gpr_deltas_inline",
        "per_day_distribution",
        "per_hour_distribution"
      ],
      "field_types": {
        "updated_at": "timestamp",
        "zaps_7d": "integer",
        "zaps_30d": "integer",
        "garden_30d": "integer",
        "sessions_30d": "integer",
        "clq_latest_score": "number | nullable",
        "clq_latest_at_bucket": "'this_week' | 'this_month' | 'older' | 'never'",
        "gpr_active_goal_count": "integer",
        "gpr_avg_7d": "number | nullable",
        "active_this_week": "boolean",
        "activity_bucket": "'today' | 'this_week' | 'older' | 'never'",
        "_last_source": "string",
        "childId": "string (FK \u2192 children.id)"
      }
    }
  }
}
