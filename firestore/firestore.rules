rules_version = '2';

// MindfulNest Firestore Security Rules v4
// Source: CANONICAL_DATA_MODEL_v1_13.md §Security Rules Summary
// COPPA-safe: no analytics, no child identifiers in logs
//
// Auth model:
//   - Therapists: Firebase Auth UID = therapist document ID
//   - Parents: Firebase Auth UID = parent document ID
//   - Children: NOT Firebase Auth users. Accessed via parent's auth.
//   - Cloud Functions: use Admin SDK (bypass these rules entirely)
//
// Security review history:
//   v1 — Initial rules from CDM table (April 16, 2026)
//   v2 — 5-fix revision after adversarial counter-agent review + 3-agent deep investigation
//     F1:  Removed parent read on therapists (parent doesn't need therapist name)
//     F2:  Therapist reads parents only via parent.linkedTherapist match
//     F8/F9: Removed narrativeEvents + arcDefinitions client rules (Cloud Function only)
//     F11: Added field-level restrictions — parent cannot write notification tracking fields
//     F15: COPPA chatEnabled gate with clarifying comment
//   v3 — 6-fix revision after blind spot deep investigation (3 agents)
//     BS1a: Invite claim race condition — require status == 'active' before claim
//     BS1b: Child create field validation — require linkedParent, linkedTherapist, displayName
//     BS1c: affectedKeys() warning comment (nested field footgun)
//     BS2:  CDM security table synced (done in CDM v1.13, not here)
//     BS3:  Bar delete prevention — split write into create/update (no delete)
//     BS4:  Invite code UUID v4 format validation
//   v4 — BS3 rewrite: value-based protected field immutability (April 16, 2026)
//     BS3-v2: Replaced affectedKeys().hasAny() with fieldUnchanged() value comparison
//       - Closes BS1c nested-field vulnerability (deep value equality, not key enumeration)
//       - Fixes C1: resource.data null on CREATE (scoped to UPDATE-only on subcollections)
//       - Renamed parentWriteTouchesProtectedFields() → anyProtectedFieldChanged()
//       - Bars rule split: CREATE (no check) / UPDATE (with check, defense-in-depth)
//       - completionLog CREATE: check removed (resource.data null + fields don't exist on subcoll)
//       - Locked decision: PROTECTED_FIELD_IMMUTABILITY_PATTERN (Directus id=125)
//       - LD-122 modified: UPDATE-only scope (Kim-approved April 16, 2026)
//   v8 — S3-POLISH-audit /audit_logs parent + therapist read rules (April 18, 2026)
//     LD-221 formalized; LD-223 parent-portal prerequisite.
//     /audit_logs: parent reads rows where resource.data.childId is a linked
//       child; linked therapist can read rows for their linked children.
//       Orphan/system events (childId == null) remain admin-SDK-only.
//       All writes continue admin-SDK-only (CFs via Admin SDK bypass rules).
//     Preflight: prod_preflight_reviews id=74.
//   v7 — S3-FS-rules-v7 non-Pattern-C collections (April 18, 2026)
//     LD-225 data minimization + LD-226 parent-child nesting applied to:
//     /sessions: client write from parent on linked child; strict hasOnly +
//       type gates + endedAt >= startedAt. NOT Pattern C (no free-text/PII).
//       coins_awarded field owned by S3-CF-coin-txn (not in allowlist here).
//     /clq_responses: therapist-only create, administered_by == auth.uid,
//       hasOnly top-level (LD-225). Parent + therapist can read own child's.
//       Nested `responses` map stays opaque — CLQ instrument schema locked
//       by a separate LD once CRI CLQ spec is canonicalized.
//     /gpr_entries: append-only. Parent OR therapist create on linked child.
//       progress_delta is number (no fabricated bounds — CRI GPR spec LD pending).
//       Corrections = new entry referencing prior (no updates).
//     /therapist_summaries/{childId}: CF-only write, therapist read via
//       direct isChildsTherapist(childId) — NO denormalized linkedTherapistIds
//       array (kept simple — one less invariant to maintain).
//     Preflight: prod_preflight_reviews id=62. 4+4 Phase 0; 11 CRITICAL +
//     3 HIGH counter-findings addressed; scope trimmed (no helper extraction,
//     no file renames, no coverage manifest change — each deferred to own row).
//   v6 — S3-CF-sanitize Pattern C staging-relay (April 18, 2026)
//     LD-171 FIRESTORE_FIELD_LEVEL_SANITIZATION_VIA_CLOUD_FUNCTION
//     /zap_staging + /wishing_garden_staging: client writes only by auth'd parent
//       on behalf of their linked child. No updates/deletes from clients.
//     /zaps + /wishing_garden_entries: admin-SDK-write-only (canonical docs
//       only written by the Cloud Function relay). Reads scoped to the
//       authoring parent + linked therapist.
//     /audit_logs: admin-SDK-only; clients never read (Console-only access).
//     Residual: staging docs are readable in Firestore PITR for up to 7 days
//       post-delete (LD-237 SHORTCUT_STAGING_PITR_WINDOW_20260418 — closure:
//       scheduled purge CF + Firestore TTL when GA).
//   v5 — COPPA hardening, Wave B1 WB-C7-T1-rules (April 18, 2026)
//     COPPA-1 (LD-216): child CREATE requires KWS consent triad
//       (parental_consent_verified=true, parental_consent_source='kws', kws_parent_id set)
//     COPPA-3 (LD-225): child field allowlist — CREATE rejects fields not in allowlist
//       Forbids: last_name, school, address, phone, childEmail, IP logs, device fingerprints,
//       photo_url, chosen_guide_name (Guide Bird permanently 'Chipper'), clinical fields
//     COPPA-11 (LD-226): parent-child nesting required — linkedParent FK must exist,
//       reject orphan child creation (already partly enforced; v5 tightens)
//     COPPA-4 (LD-218): retention_clock_started_at added to protected fields (Cloud Function only)

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ──────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isTherapist() {
      return exists(/databases/$(database)/documents/therapists/$(request.auth.uid));
    }

    function isParent() {
      return exists(/databases/$(database)/documents/parents/$(request.auth.uid));
    }

    function getChild(childId) {
      return get(/databases/$(database)/documents/children/$(childId)).data;
    }

    function isChildsTherapist(childId) {
      let childData = getChild(childId);
      return childData != null && childData.linkedTherapist == request.auth.uid;
    }

    function isChildsParent(childId) {
      let childData = getChild(childId);
      return childData != null && childData.linkedParent == request.auth.uid;
    }

    // ─── arc-entitlement helpers (overnight 2026-04-19, deliverable B) ──
    // Maps a moduleId (e.g. 'M7') to the arc key the parent must hold an
    // entitlement for (e.g. 'arc_2'). Today's product canon: M1-M6 = arc_1,
    // M7-M12 = arc_2, M13-M18 = arc_3, M19-M24 = arc_4. Update in lockstep
    // if module renumbering ever happens.
    //
    // Returns null when the moduleId does not match the M{N} pattern, so
    // the caller can fall back to a hard deny for unknown modules.
    function moduleArcKey(moduleId) {
      // Firestore Rules v2 has no .substring() string method (the supported
      // string ops are lower/upper/trim/replace/matches/size/split/toUtf8).
      // We validate the M{N} pattern with matches() and then partition the
      // 24-module space by explicit list membership. Returning null for any
      // moduleId that doesn't match M1..M24 lets the caller hard-deny.
      return !moduleId.matches('^M([1-9]|1[0-9]|2[0-4])$') ? null
        : moduleId in ['M1','M2','M3','M4','M5','M6']        ? 'arc_1'
        : moduleId in ['M7','M8','M9','M10','M11','M12']     ? 'arc_2'
        : moduleId in ['M13','M14','M15','M16','M17','M18']  ? 'arc_3'
        : 'arc_4';
    }

    function hasArcEntitlementForModule(moduleId) {
      let arcKey = moduleArcKey(moduleId);
      let parent = exists(/databases/$(database)/documents/parents/$(request.auth.uid))
        ? get(/databases/$(database)/documents/parents/$(request.auth.uid)).data
        : null;
      return arcKey != null
        && parent != null
        && parent.entitlements != null
        && parent.entitlements[arcKey] == true;
    }

    // Fields that ONLY Cloud Functions can write (notification tracking).
    // These are server-side concerns — parent device never needs to touch them.
    // Directus prod_locked_decisions ID 105 (CHILD_FIELD_WRITE_RESTRICTIONS).
    //
    // NOTE: Therapist-facing summary fields (totalSessions, sessionsThisWeek,
    // domainSessionCounts, completions, lastActivityAt, engagementStatus, weekStartDate)
    // are client-writable for MVP because module completion batch runs client-side.
    // V2: Move completion writes to Cloud Functions, then add these to protected list.
    //
    // ⚠️ BS1c BAN: Do NOT use .diff().affectedKeys() for protected-field checks
    // anywhere in this project. affectedKeys() returns TOP-LEVEL keys only — nested
    // map mutations bypass it silently. Use fieldUnchanged() (value comparison) instead.
    // Locked decision: PROTECTED_FIELD_IMMUTABILITY_PATTERN (Directus id=125).
    //
    // fieldUnchanged(field): Returns true if the field's value is identical between
    // the existing document (resource.data) and the incoming write (request.resource.data).
    // Uses .get(field, null) so missing fields default to null on both sides.
    // Performs deep value comparison — catches nested map/array mutations.
    // IMPORTANT: Only valid on UPDATE operations. On CREATE, resource.data is undefined
    // and .get() throws "Null value error" (empirically verified, emulator v1.20.4).
    function fieldUnchanged(field) {
      return request.resource.data.get(field, null) == resource.data.get(field, null);
    }

    // Returns true if ANY protected field was changed (value differs between old and new).
    // Used to DENY parent writes that attempt to modify protected fields.
    // Call sites: child UPDATE (line ~165), bars UPDATE (line ~200).
    // NOT called on CREATE operations — see fieldUnchanged() comment above.
    //
    // v5 COPPA additions (LD-218 retention, LD-216 consent triad):
    //   - retention_clock_started_at (Cloud Function sets when program completes)
    //   - parental_consent_verified (KWS callback sets once)
    //   - parental_consent_source (KWS sets once)
    //   - kws_parent_id (KWS sets once)
    function anyProtectedFieldChanged() {
      return !fieldUnchanged('parentNotifiedSkills')
        || !fieldUnchanged('therapistFirstCompletionNotified')
        || !fieldUnchanged('inactivityNotifiedAt')
        || !fieldUnchanged('linkedParent')
        || !fieldUnchanged('linkedTherapist')
        || !fieldUnchanged('retention_clock_started_at')
        || !fieldUnchanged('parental_consent_verified')
        || !fieldUnchanged('parental_consent_source')
        || !fieldUnchanged('kws_parent_id');
    }

    // ─── COPPA helpers (v5) ────────────────────────────────────────
    //
    // hasValidKwsConsent(): returns true if the child CREATE request has the
    // KWS consent triad intact (LD-216 COPPA_VPC_VIA_KWS_ONLY).
    // All three must be present + correct — Firestore does not trust clients
    // to set verified=true without source='kws' and a kws_parent_id.
    function hasValidKwsConsent() {
      return request.resource.data.parental_consent_verified == true
        && request.resource.data.parental_consent_source == 'kws'
        && request.resource.data.kws_parent_id is string
        && request.resource.data.kws_parent_id.size() > 0;
    }

    // childFieldAllowlist(): returns true if the child CREATE request's fields
    // are all in the LD-225 COPPA_DATA_MINIMIZATION allowlist.
    // Hard-deny any attempt to write: last_name, school, address, phone,
    // childEmail, IP logs, device fingerprints, photo_url, clinical notes,
    // CLQ/GPR scores on child record, chosen_guide_name (Guide Bird is 'Chipper').
    //
    // NOTE: Allowlist is set-level — rule rejects CREATE containing ANY field
    // outside this list. UPDATE inherits protected-field check; field additions
    // via UPDATE are blocked via the same hasOnly pattern where needed.
    function childFieldAllowlist() {
      return request.resource.data.keys().hasOnly([
        // Core identity + relationships (required)
        'linkedParent', 'linkedTherapist', 'displayName',
        // Content personalization (LD-225)
        'date_of_birth', 'gender',
        // Program state
        'current_module_id', 'current_phase', 'current_checkpoint_id',
        // voice_cache_ids REMOVED 2026-04-18 per LD-281 NO_RUNTIME_TTS_PERSONALIZATION_V1 — no per-child audio cache exists (app ships single-MP4 atomic deliverables).
        // Consent (KWS)
        'parental_consent_verified', 'parental_consent_source', 'kws_parent_id',
        'consent_status', 'consent_scope',
        // Retention
        'last_session_timestamp', 'retention_clock_started_at',
        // Audit
        'created_at', 'updated_at',
        // Legacy fields carried forward for compatibility (v1 schema):
        'preferredTechniques', 'chatEnabled',
        'parentNotifiedSkills', 'therapistFirstCompletionNotified', 'inactivityNotifiedAt',
        // Therapist-facing summary fields (v2 will move to Cloud Functions — for now, client-writable)
        'totalSessions', 'sessionsThisWeek', 'domainSessionCounts',
        'completions', 'lastActivityAt', 'engagementStatus', 'weekStartDate',
      ]);
    }

    // ─── therapists/{therapistId} ──────────────────────────────────
    // CDM: Therapist = own doc read/write
    // CDM (updated v3): Parent = no access
    // CDM: Child = no access
    //
    // F1 FIX: Parent does NOT need to read therapist doc at all.
    // "Your therapist recommended this technique" uses child.preferredTechniques,
    // not therapist.displayName. No parent read rule needed.
    // Directus prod_locked_decisions ID 103.

    // BS2 FIX: Therapist can read + update own doc, but NOT delete.
    // Account deactivation/unlink is handled by Cloud Functions only
    // (soft-delete with status: "deactivated", not hard delete).
    // Prevents orphaned children/parents pointing to deleted therapist doc.
    // Directus prod_locked_decisions ID TBD (THERAPIST_NO_CLIENT_DELETE).
    match /therapists/{therapistId} {
      allow read, update: if isOwner(therapistId);
    }

    // ─── parents/{parentId} ────────────────────────────────────────
    // CDM: Parent = own doc read/write
    // CDM: Therapist = linked parent read only
    // CDM: Child = no access
    //
    // F2 FIX: Therapist can ONLY read parents where parent.linkedTherapist
    // matches the therapist's UID. Multi-therapist families: each child links
    // independently. Parent doc's linkedTherapist = first/primary therapist.
    // Child-level isolation handles the rest.

    match /parents/{parentId} {
      allow read, write: if isOwner(parentId);

      // Therapist can read ONLY their linked parents
      allow read: if isAuthenticated()
        && isTherapist()
        && resource.data.linkedTherapist == request.auth.uid;
    }

    // ─── children/{childId} ────────────────────────────────────────
    // CDM: Therapist = read all linked children. Write preferredTechniques only.
    // CDM: Parent = read/write game state on own linked children.
    // CDM: Child = no direct auth (via parent device).
    //
    // F11 FIX: Parent CANNOT write notification tracking fields (Cloud Function only).
    //
    // F15: COPPA enforcement — chatEnabled requires parent coppaChatConsent.
    // This is ONE layer of COPPA compliance. Separate from: COPPA-compliant
    // parental consent verification at signup (product/legal flow, not Firestore rules).
    // Both are needed. Neither replaces the other.

    match /children/{childId} {
      // Parent can read their linked child
      allow read: if isAuthenticated() && isChildsParent(childId);

      // BS1b FIX: Parent can CREATE a new child doc during invite claim flow.
      // Required fields enforced: linkedParent must be the creating parent,
      // linkedTherapist and displayName must be present.
      //
      // v5 COPPA ADDITIONS:
      //   COPPA-1 (LD-216): KWS consent triad REQUIRED — verified+source+id
      //   COPPA-3 (LD-225): field allowlist ENFORCED — reject fields like last_name
      //   COPPA-11 (LD-226): linkedParent FK required (already in original rule)
      allow create: if isAuthenticated()
        && isParent()
        && request.resource.data.linkedParent == request.auth.uid
        && request.resource.data.linkedTherapist != null
        && request.resource.data.displayName != null
        && hasValidKwsConsent()
        && childFieldAllowlist();

      // Parent can UPDATE their linked child — with two gates:
      // 1. Cannot touch protected fields (notification tracking)
      // 2. Cannot set chatEnabled=true without parent coppaChatConsent
      allow update: if isAuthenticated()
        && isChildsParent(childId)
        && !anyProtectedFieldChanged()
        && (
          !request.resource.data.chatEnabled
          || get(/databases/$(database)/documents/parents/$(request.auth.uid)).data.coppaChatConsent == true
        );

      // Therapist can read linked children
      allow read: if isAuthenticated() && isChildsTherapist(childId);

      // Therapist can write ONLY preferredTechniques on linked children
      allow update: if isAuthenticated()
        && isChildsTherapist(childId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['preferredTechniques']);

      // ─── children/{childId}/bars/{barId} ───────────────────────
      // CDM: Therapist = linked children read
      // CDM: Parent = own linked children read/create/update (NO delete)
      //
      // BS3 FIX: Split write into create + update. Delete is NOT allowed.
      // Bar deletion mid-progress would corrupt game state (activeBarId
      // points to nothing). If "reset progress" is needed, use a Cloud Function.

      // BS3-v2: Bars rules split into CREATE and UPDATE with different guards.
      // Protected field check (anyProtectedFieldChanged) is on UPDATE only.
      //
      // INTENTIONAL: No protected-field check on bars CREATE because:
      //   (a) resource.data is null on CREATE → fieldUnchanged() throws (C1 finding)
      //   (b) Protected fields exist only on /children/{id}, not on bars subcollection
      // LD-122 modified (Kim-approved April 16, 2026) to UPDATE-only scope.
      // Emulator test: bars_create_has_no_protected_field_check_intentional

      match /bars/{barId} {
        allow read: if isAuthenticated() && isChildsParent(childId);
        allow create: if isAuthenticated()
          && isChildsParent(childId);
        allow update: if isAuthenticated()
          && isChildsParent(childId)
          && !anyProtectedFieldChanged();
        allow read: if isAuthenticated() && isChildsTherapist(childId);
      }

      // ─── children/{childId}/completionLog/{logId} ──────────────
      // CDM: Therapist = linked children read
      // CDM table says "Parent: No access" — but module completion needs
      // client-side create for MVP (no Cloud Functions yet).

      // INTENTIONAL: No protected-field check on completionLog CREATE — same
      // rationale as bars CREATE above (C1 + fields don't exist on subcoll docs).
      match /completionLog/{logId} {
        allow create: if isAuthenticated()
          && isChildsParent(childId);
        allow read: if isAuthenticated() && isChildsTherapist(childId);
      }
    }

    // ─── modules/{moduleId} ────────────────────────────────────────
    // CDM: All authenticated users = read published only
    // Write: admin/Cloud Functions only

    match /modules/{moduleId} {
      allow read: if isAuthenticated()
        && resource.data.status == 'published';

      // ─── modules/{moduleId}/assets/{assetId} ────────────────────────
      // Per-arc entitlement gate (added 2026-04-19, overnight deliverable B).
      // Parents pay $499 one-time for the program; entitlements unlock arcs
      // incrementally (parents get arc_1 immediately on purchase; arc_2+ as
      // the child progresses or on subsequent purchases).
      //
      // The module-id → arc mapping is hardcoded here. Today's product canon
      // (M1-M6 = arc_1, M7-M12 = arc_2, M13+ as more arcs ship) means the
      // mapping is stable — but if module re-numbering ever happens, this
      // rule must be updated in lockstep.
      //
      // Cloud Functions write entitlements; clients only read.
      match /assets/{assetId} {
        allow read: if isAuthenticated() && hasArcEntitlementForModule(moduleId);
      }
    }

    // ─── narrativeEvents/{eventId} ─────────────────────────────────
    // F8 FIX: NO CLIENT READ RULES.
    // Narrative engine runs server-side (Cloud Functions with Admin SDK).
    // Client never queries this collection. Spell Road uses modules only.
    // No match rule = default deny for all clients.

    // ─── arcDefinitions/{arcId} ────────────────────────────────────
    // F9 FIX: NO CLIENT READ RULES.
    // Same rationale as narrativeEvents — server-side only.
    // No match rule = default deny for all clients.

    // ─── storeItems/{itemId} ───────────────────────────────────────
    // All authenticated users: read only (static catalog)
    // Write: admin/Cloud Functions only

    match /storeItems/{itemId} {
      allow read: if isAuthenticated();
    }

    // ─── therapistInvites/{inviteCode} ─────────────────────────────
    // CDM: Therapist = own invites read/write
    // CDM: Parent = claim by code, read/write status
    // CDM: Child = no access
    //
    // BS4 FIX: Invite codes MUST be UUID v4 format (122-bit entropy).
    // Generated server-side only (Cloud Function or Admin SDK).
    // Format validated on create to prevent sequential/guessable codes.
    //
    // BS1a FIX: Parent can only claim invites with status == 'active'.
    // Prevents race condition where two parents claim the same code.

    // ─── Child-authored content: Zap + Wishing Garden (LD-171) ─────
    //
    // Pattern C staging-relay: clients write to `_staging` collections; a
    // Cloud Function sanitizes (field allowlist + PII scan) and writes the
    // canonical document. Canonical paths are admin-SDK-write-only.
    //
    // See: functions/src/triggers/firestore/sanitizeZapStaging.ts
    //      functions/src/triggers/firestore/sanitizeWishingGardenStaging.ts
    // Preflight: prod_preflight_reviews id=61.

    match /zap_staging/{stagingId} {
      // Parent writes on behalf of their linked child (children have no Auth).
      allow create: if isAuthenticated()
        && isParent()
        && request.resource.data.childId is string
        && isChildsParent(request.resource.data.childId);
      // Parent reads their own staging doc (for _sanitize_status updates).
      allow read: if isAuthenticated()
        && isParent()
        && isChildsParent(resource.data.childId);
      // Clients never update/delete — CF relay handles status writes + cleanup.
      allow update, delete: if false;
    }

    match /wishing_garden_staging/{stagingId} {
      allow create: if isAuthenticated()
        && isParent()
        && request.resource.data.childId is string
        && isChildsParent(request.resource.data.childId);
      allow read: if isAuthenticated()
        && isParent()
        && isChildsParent(resource.data.childId);
      allow update, delete: if false;
    }

    match /zaps/{zapId} {
      // Canonical Zap doc: CF relay writes only. Path IS the trust boundary.
      allow create, update, delete: if false;
      allow read: if isAuthenticated()
        && (
          (isParent() && isChildsParent(resource.data.childId))
          || (isTherapist() && isChildsTherapist(resource.data.childId))
        );
    }

    match /wishing_garden_entries/{entryId} {
      allow create, update, delete: if false;
      allow read: if isAuthenticated()
        && (
          (isParent() && isChildsParent(resource.data.childId))
          || (isTherapist() && isChildsTherapist(resource.data.childId))
        );
    }

    match /audit_logs/{entryId} {
      // v8: CF-only writes retained; reads scoped to linked parent or therapist
      // when the row carries a non-null childId. Orphan rows (childId == null)
      // stay opaque to clients (parent signup, therapist invite, system events).
      allow read: if isAuthenticated()
        && resource.data.childId != null
        && (
          (isParent() && isChildsParent(resource.data.childId))
          || (isTherapist() && isChildsTherapist(resource.data.childId))
        );
      allow write: if false;
    }

    // ─── Session + CRI assessment + therapist summaries (v7) ───────
    //
    // Direct client writes for sessions/clq_responses/gpr_entries (no Pattern C
    // relay — content has no PII/free-text to sanitize). therapist_summaries
    // is CF-written via admin SDK (S3-CF-therapist-summary, LD-165).
    //
    // Preflight: prod_preflight_reviews id=62.

    match /sessions/{sessionId} {
      allow read: if isAuthenticated()
        && (
          (isParent() && isChildsParent(resource.data.childId))
          || (isTherapist() && isChildsTherapist(resource.data.childId))
        );
      allow create: if isAuthenticated()
        && isParent()
        && isChildsParent(request.resource.data.childId)
        && request.resource.data.keys().hasAll(['childId', 'startedAt', 'endedAt'])
        && request.resource.data.keys().hasOnly(
             ['childId', 'moduleId', 'phase', 'startedAt', 'endedAt', 'completionStatus'])
        && request.resource.data.startedAt is timestamp
        && request.resource.data.endedAt is timestamp
        && request.resource.data.endedAt >= request.resource.data.startedAt
        && (
          !('completionStatus' in request.resource.data)
          || request.resource.data.completionStatus in ['in_progress', 'completed', 'abandoned']
        );
      // Append-only; coin-txn and summary CFs read, never mutate.
      allow update, delete: if false;
    }

    match /clq_responses/{docId} {
      allow read: if isAuthenticated()
        && (
          (isParent() && isChildsParent(resource.data.childId))
          || (isTherapist() && isChildsTherapist(resource.data.childId))
        );
      allow create: if isAuthenticated()
        && isTherapist()
        && isChildsTherapist(request.resource.data.childId)
        && request.auth.uid == request.resource.data.administered_by
        && request.resource.data.keys().hasAll(['childId', 'administered_at', 'administered_by'])
        && request.resource.data.keys().hasOnly(
             ['childId', 'administered_at', 'administered_by', 'responses', 'is_baseline']);
      // Clinical record immutable. Amendments pattern (if needed) ships separately.
      allow update, delete: if false;
    }

    match /gpr_entries/{entryId} {
      allow read: if isAuthenticated()
        && (
          (isParent() && isChildsParent(resource.data.childId))
          || (isTherapist() && isChildsTherapist(resource.data.childId))
        );
      allow create: if isAuthenticated()
        && (
          (isParent() && isChildsParent(request.resource.data.childId))
          || (isTherapist() && isChildsTherapist(request.resource.data.childId))
        )
        && request.resource.data.keys().hasAll(['childId', 'recorded_at'])
        && request.resource.data.keys().hasOnly(
             ['childId', 'recorded_at', 'goal_id', 'progress_delta', 'notes'])
        && (
          !('progress_delta' in request.resource.data)
          || request.resource.data.progress_delta is number
        );
      // Append-only — corrections = new entry referencing prior.
      allow update, delete: if false;
    }

    match /therapist_summaries/{childId} {
      // Document ID = childId; read if requester is this child's linked therapist.
      allow read: if isAuthenticated()
        && isTherapist()
        && isChildsTherapist(childId);
      // CF-only writes via admin SDK. All client mutation denied.
      allow create, update, delete: if false;
    }

    // ────────────────────────────────────────────────────────────────
    // LD-290 STRIPE_IDEMPOTENCY_KEY_V1 (id=300) CLAUSE 2: stripe_events is the
    // webhook dedup table. Cloud Functions write via Admin SDK (bypasses these
    // rules). NO client may read or write — leaking event payloads exposes
    // Stripe metadata + customer email. NO exceptions.
    match /stripe_events/{eventId} {
      allow read, write: if false;
    }

    // LD-290 CLAUSE 1: per-purchase attempt counters. Server-only.
    match /purchases/{childId}/attempts/{sku} {
      allow read, write: if false;
    }

    // ────────────────────────────────────────────────────────────────
    match /therapistInvites/{inviteCode} {
      // BS4: Validate UUID v4 format on create
      // Therapist can create new invites (server-generated UUID code)
      allow create: if isAuthenticated()
        && request.resource.data.therapistId == request.auth.uid
        && inviteCode.matches('[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}');

      // Therapist can read/write their own invites
      allow read, write: if isAuthenticated()
        && resource.data.therapistId == request.auth.uid;

      // Parent can read any invite (needed for code lookup during claim flow)
      allow read: if isAuthenticated() && isParent();

      // BS1a FIX: Parent can claim ONLY active invites (prevents race condition)
      allow update: if isAuthenticated()
        && isParent()
        && resource.data.status == 'active'
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'claimedByParent', 'childId', 'claimedAt']);
    }
  }
}
