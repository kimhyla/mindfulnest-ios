// Firebase Storage security rules — MindfulNest V1
//
// All direct client reads/writes are denied. Signed URLs generated by the
// generateModuleDownloadUrl Cloud Function use service-account credentials
// and bypass these rules (that is by design — the CF enforces auth +
// entitlement before issuing the URL). This file is defense-in-depth:
// it prevents any path where a client obtains a raw Storage reference
// and reads an asset without going through the CF.
//
// LD-406: CDN = Firebase Storage mindfulnestkids.firebasestorage.app;
//         signed URLs from D1 CF only; app never calls Storage directly.
// Stream C catalog wiring (preflight 156).

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
