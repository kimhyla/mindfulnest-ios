# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# DevTelemetry per-launch auth token (LD-157 4b-hardened (ii))
mn-devtelemetry-token
/tmp/mn-devtelemetry-token

# Generated production .ipa from local EAS builds (CI artifact)
mindfulnest-production.ipa
ipa-extract/

# Firestore emulator runtime log (regenerated on every emulator start)
firestore-debug.log

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Maestro test artifacts (regeneratable)
*.png
!assets/*.png
/.maestro

# Firebase native config files (contain project credentials — never commit)
GoogleService-Info.plist
google-services.json

